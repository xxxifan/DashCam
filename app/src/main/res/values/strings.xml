<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">DashCam</string>
    <string name="recording_confirm_title">开始录制？</string>
    <string name="recording_confirm_body">录制将通过常驻通知持续运行。开始后你可以按电源键锁屏，DashCam 会尽量继续录制。</string>
    <string name="recording_confirm_start">开始录制</string>
    <string name="recording_confirm_cancel">取消</string>
    <string name="battery_optimization_prompt_title">允许后台持续录制？</string>
    <string name="battery_optimization_prompt_body">DashCam 长时间录制依赖前台服务。建议在系统电池设置中允许 DashCam 不受电池优化限制，减少锁屏或后台时被系统暂停的概率。此提示只会出现一次。</string>
    <string name="battery_optimization_prompt_confirm">去开启</string>
    <string name="battery_optimization_prompt_dismiss">稍后</string>
    <string name="battery_optimization_settings_failed">无法打开电池优化设置，请在系统设置中手动允许 DashCam 后台运行。</string>
    <string name="recording_start_body">DashCam 正在录制。你可以按电源键锁屏。</string>
    <string name="recording_black_screen_body">黑屏省电模式已开启，录制仍在继续。</string>
    <string name="recording_auto_downgrade_body">资源紧张，已自动调整为更稳定的录制质量。</string>
    <string name="recording_emergency_stop_body">由于设备状态紧急，录制已停止。</string>
    <string name="recording_lock_screen_unstable_body">锁屏后相机连续中断，录制已停止。</string>
    <string name="recording_lock_screen_fallback_guidance">请保持 DashCam 停留在前台并让屏幕常亮后重试；如果仍不稳定，请降低防抖或视频质量。</string>
    <string name="recording_pipeline_unstable_body">录制管线不稳定，录制已停止。</string>
    <string name="recording_pipeline_fallback_guidance">请尝试切换到 720p30、SDR、标准或关闭防抖后重新开始录制。</string>
    <string name="storage_insufficient_title">存储空间不足</string>
    <string name="storage_insufficient_body">当前可用空间不足，无法安全开始录制。请释放空间，或降低画质后重试。</string>
    <string name="storage_quota_too_small_body">可用于录制的空间低于 2GB，已尝试切换到较低画质。</string>
    <string name="storage_cleanup_failed_body">可用于下一段录制的安全空间不足，录制已停止。</string>
    <string name="thermal_notice_body">设备温度升高，录制仍在继续。</string>
    <string name="thermal_downgrade_body">设备温度较高，已降低视频质量以保持录制。</string>
    <string name="thermal_emergency_stop_body">设备温度过高，录制已停止以保护设备。</string>
    <string name="battery_low_body">电量较低，建议连接电源。</string>
    <string name="battery_downgrade_body">电量较低且未连接电源，已降低视频质量以延长录制。</string>
    <string name="battery_emergency_stop_body">电量过低，录制已停止以避免视频损坏。</string>
</resources>
